# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# real CV / personal data (public repo ships a placeholder resume.ts instead)
src/data/resume.local.ts

# job-application materials (cover letters etc. — contain real PII, never publish)
applications/

# Claude Code local config + vendored skills — track only our own skill/command
.claude/settings.json
.claude/settings.local.json
.claude/skills/*
!.claude/skills/screen-remote-jobs/
.claude/commands/*
!.claude/commands/screen-remote-jobs.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# job bot artifacts
.job-cache.json
.jobs-raw.json
.jobs.db
.jobs.db-shm
.jobs.db-wal
jobs-digest.html
